DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

# LLM. "openai" for real, "echo" for keyless local dev.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Embedder. "openai" uses text-embedding-3-small (1536 dim).
# "local" uses sentence-transformers/all-MiniLM-L6-v2 (384 dim).
# Switch the migration's embedding column to match if you change this.
EMBEDDER_PROVIDER=openai
EMBEDDER_MODEL=text-embedding-3-small

# Retrieval params.
RETRIEVE_TOP_K=20
RERANK_TOP_K=6
RRF_K=60

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
